# Template cấu hình các biến môi trường cho dự án
# HƯỚNG DẪN: Sao chép tệp này thành tệp tên ".env" tại thư mục gốc và điền các giá trị thực tế của bạn.

# Email học thuật của sinh viên FPT (Bắt buộc theo hướng dẫn)
ACADEMIC_MAIL=your_student_email@fpt.edu.vn

# API Key của OpenAlex (Tùy chọn - Để tăng giới hạn kết nối hàng ngày lên 100K)
OPENALEX_API_KEY=
